{
  "name": "ticket-manager",
  "private": true,
  "workspaces": ["client", "server", "core"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:client": "bun run --filter client dev",
    "dev:server": "bun run --filter server dev",
    "test": "bun run --filter client test",
    "test:watch": "bun run --filter client test:watch",
    "test:e2e": "bunx playwright test",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:install": "bunx playwright install chromium"
  },
  "devDependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/pg": "^8.11.6",
    "client": "workspace:*",
    "dotenv": "^16.4.7",
    "jsdom": "^29.0.2",
    "pg": "^8.13.1",
    "vitest": "^4.1.4"
  }
}
