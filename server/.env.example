# ── Database ──
# Railway provides this automatically when you add a PostgreSQL service
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/helpdesk?schema=public"

# ── Better Auth ──
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Production: your Railway app URL (e.g. https://your-app.up.railway.app)
BETTER_AUTH_URL="http://localhost:3000"
# Production: same as BETTER_AUTH_URL (client is served from the same origin)
CLIENT_URL="http://localhost:5173"

# ── Admin Seed User ──
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="change-me-use-strong-password"

# ── AI (OpenAI-compatible) ──
OPENAI_API_KEY="sk-your-openai-api-key"

# ── Monitoring (optional) ──
SENTRY_DSN=""
